# Banco de dados — próprio do Juit, isolado do banco do advocatix
JUIT_DATABASE_URL="postgresql://user:password@localhost:5432/juit"

# App
PORT="3010"
NODE_ENV="development"

# CORS — origens autorizadas a chamar a API diretamente do browser
FRONTEND_URL="http://localhost:3011"

# Crawler — CJSG do TJSP exige reCAPTCHA v3, precisa de um browser real
# (via CDP). Em produção use BROWSERBASE_API_KEY. Em dev local, sem essa
# chave, cai para um Chrome instalado na máquina (PLAYWRIGHT_CHROMIUM_PATH).
BROWSERBASE_API_KEY=""
PLAYWRIGHT_CHROMIUM_PATH="C:/Program Files/Google/Chrome/Application/chrome.exe"

# Crawler — TJMG usa CAPTCHA de imagem clássico em toda busca por
# palavra-chave. Resolvido via CapSolver (ImageToTextTask).
CAPSOLVER_API_KEY=""
